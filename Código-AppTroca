import React, { useState, useEffect } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  FlatList,
  StyleSheet,
  Image,
  SafeAreaView,
  Modal,
  Alert,
  KeyboardAvoidingView,
  Platform,
  ScrollView,
  Dimensions,
} from 'react-native';
import * as ImagePicker from 'expo-image-picker';
import AsyncStorage from '@react-native-async-storage/async-storage';

const { width } = Dimensions.get('window');
const isDesktop = width > 768;

export default function App() {
  const [tela, setTela] = useState('splash');
  const [logado, setLogado] = useState(false);
  const [naTelaDeCadastro, setNaTelaDeCadastro] = useState(false);
  const [abaAtiva, setAbaAtiva] = useState('home');
  const [mostrarSenha, setMostrarSenha] = useState(false);

  const [email, setEmail] = useState('');
  const [senha, setSenha] = useState('');
  const [telefone, setTelefone] = useState('');
  const [usuarioAtual, setUsuarioAtual] = useState(null);

  const [titulo, setTitulo] = useState('');
  const [descricao, setDescricao] = useState('');
  const [imagem, setImagem] = useState(null);
  const [lista, setLista] = useState([]);

  const [perfilVisivel, setPerfilVisivel] = useState(false);
  const [anuncianteSelecionado, setAnuncianteSelecionado] = useState(null);

  useEffect(() => {
    const timer = setTimeout(() => {
      setTela('login');
    }, 2500);
    return () => clearTimeout(timer);
  }, []);

  useEffect(() => {
    carregarDados();
  }, []);

  const carregarDados = async () => {
    try {
      const valor = await AsyncStorage.getItem('@itens_save');
      if (valor !== null) setLista(JSON.parse(valor));
    } catch (e) {}
  };

  const cadastrarUsuario = async () => {
    if (!email || !senha || !telefone) {
      Alert.alert('Erro', 'Preencha todos os campos.');
      return;
    }
    try {
      const dadosUser = { email, senha, telefone };
      await AsyncStorage.setItem(
        '@usuario_cadastro',
        JSON.stringify(dadosUser)
      );
      Alert.alert('Sucesso', 'Cadastro realizado!');
      setNaTelaDeCadastro(false);
    } catch (e) {}
  };

  const realizarLogin = async () => {
    try {
      const dados = await AsyncStorage.getItem('@usuario_cadastro');
      if (dados === null) {
        Alert.alert('Atenção', 'Usuário não cadastrado.');
        return;
      }
      const usuario = JSON.parse(dados);
      if (
        usuario.email.toLowerCase() === email.toLowerCase() &&
        usuario.senha === senha
      ) {
        setUsuarioAtual(usuario);
        setLogado(true);
      } else {
        Alert.alert('Erro', 'E-mail ou senha incorretos.');
      }
    } catch (e) {}
  };

  const escolherImagem = async () => {
    let result = await ImagePicker.launchImageLibraryAsync({
      mediaTypes: ImagePicker.MediaTypeOptions.Images,
      allowsEditing: true,
      aspect: [4, 3],
      quality: 1,
    });
    if (!result.canceled) setImagem(result.assets[0].uri);
  };

  const adicionarItem = () => {
    if (!titulo || !descricao) {
      Alert.alert('Atenção', 'Preencha título e descrição.');
      return;
    }
    const novoItem = {
      id: Math.random().toString(),
      titulo,
      descricao,
      imagem,
      usuarioEmail: usuarioAtual.email,
      usuarioTel: usuarioAtual.telefone,
    };
    const novaLista = [novoItem, ...lista];
    setLista(novaLista);
    AsyncStorage.setItem('@itens_save', JSON.stringify(novaLista));
    setTitulo('');
    setDescricao('');
    setImagem(null);
    setAbaAtiva('home');
  };

  const removerItem = (id) => {
    const novaLista = lista.filter((item) => item.id !== id);
    setLista(novaLista);
    AsyncStorage.setItem('@itens_save', JSON.stringify(novaLista));
  };

  if (tela === 'splash') {
    return (
      <View style={styles.splashContainer}>
        <Text style={styles.logoSplash}>🌱 EcoTroca</Text>
        <Text style={styles.subSplash}>Troque • Reutilize • Transforme</Text>
      </View>
    );
  }

  if (!logado) {
    return (
      <KeyboardAvoidingView
        behavior={Platform.OS === 'ios' ? 'padding' : 'height'}
        style={{ flex: 1, backgroundColor: '#fff' }}>
        <ScrollView contentContainerStyle={styles.scrollCenter}>
          <View style={styles.containerLogin}>
            <Text style={styles.logo}>🌱 EcoTroca</Text>
            <Text style={styles.subtituloLogin}>
              {naTelaDeCadastro ? 'Crie sua conta' : 'Acesse sua conta'}
            </Text>
            <TextInput
              placeholder="E-mail"
              style={styles.inputLogin}
              value={email}
              onChangeText={setEmail}
              autoCapitalize="none"
            />
            {naTelaDeCadastro && (
              <TextInput
                placeholder="WhatsApp"
                style={styles.inputLogin}
                value={telefone}
                onChangeText={setTelefone}
                keyboardType="phone-pad"
              />
            )}
            <View style={styles.senhaContainer}>
              <TextInput
                placeholder="Senha"
                style={[
                  styles.inputLogin,
                  { flex: 1, marginBottom: 0, borderBottomWidth: 0 },
                ]}
                value={senha}
                onChangeText={setSenha}
                secureTextEntry={!mostrarSenha}
              />
              <TouchableOpacity
                onPress={() => setMostrarSenha(!mostrarSenha)}
                style={styles.olhoBotao}>
                <Text style={styles.olhoTexto}>
                  {mostrarSenha ? 'Ocultar' : 'Ver'}
                </Text>
              </TouchableOpacity>
            </View>
            <TouchableOpacity
              style={styles.buttonLogin}
              onPress={naTelaDeCadastro ? cadastrarUsuario : realizarLogin}>
              <Text style={styles.buttonText}>
                {naTelaDeCadastro ? 'REGISTRAR' : 'ENTRAR'}
              </Text>
            </TouchableOpacity>
            <TouchableOpacity
              onPress={() => setNaTelaDeCadastro(!naTelaDeCadastro)}
              style={{ marginTop: 20 }}>
              <Text style={styles.linkTexto}>
                {naTelaDeCadastro ? 'Já tenho conta' : 'Cadastre-se'}
              </Text>
            </TouchableOpacity>
          </View>
        </ScrollView>
      </KeyboardAvoidingView>
    );
  }

  return (
    <SafeAreaView style={styles.container}>
      <View style={styles.mainWrapper}>
        <View style={styles.headerRow}>
          <Text style={styles.headerTitle}>
            {abaAtiva === 'home' ? '🏠 Início' : 'Anunciar'}
          </Text>
          <TouchableOpacity onPress={() => setLogado(false)}>
            <Text style={styles.sairTexto}>Sair</Text>
          </TouchableOpacity>
        </View>

        {abaAtiva === 'perfil' ? (
          <KeyboardAvoidingView
            behavior={Platform.OS === 'ios' ? 'padding' : null}
            style={{ flex: 1 }}>
            <ScrollView>
              <View style={styles.cardForm}>
                <TextInput
                  placeholder="Título do item"
                  style={styles.inputAnunciar}
                  value={titulo}
                  onChangeText={setTitulo}
                />
                <TextInput
                  placeholder="Descrição detalhada"
                  style={[styles.inputAnunciar, { minHeight: 80 }]}
                  value={descricao}
                  onChangeText={setDescricao}
                  multiline
                />
                <TouchableOpacity
                  style={styles.btnFotoTracejado}
                  onPress={escolherImagem}>
                  <Text style={styles.btnFotoTexto}>
                    📸 {imagem ? 'Trocar Foto' : 'Selecionar Foto'}
                  </Text>
                </TouchableOpacity>
                {imagem && (
                  <Image
                    source={{ uri: imagem }}
                    style={styles.previewImagem}
                  />
                )}
                <TouchableOpacity
                  style={styles.btnPublicar}
                  onPress={adicionarItem}>
                  <Text style={styles.btnPublicarTexto}>PUBLICAR</Text>
                </TouchableOpacity>
              </View>
              <View style={{ height: 180 }} />
            </ScrollView>
          </KeyboardAvoidingView>
        ) : (
          <FlatList
            data={lista}
            keyExtractor={(item) => item.id}
            contentContainerStyle={{ paddingBottom: 200 }}
            numColumns={isDesktop ? 2 : 1}
            key={isDesktop ? 'desktop' : 'mobile'}
            renderItem={({ item }) => (
              <View
                style={[styles.cardItem, isDesktop && { flex: 1, margin: 10 }]}>
                {item.imagem && (
                  <Image source={{ uri: item.imagem }} style={styles.cardImg} />
                )}
                <View style={styles.cardContent}>
                  <View style={styles.row}>
                    <Text style={styles.cardTitle}>{item.titulo}</Text>
                    {item.usuarioEmail === usuarioAtual.email && (
                      <TouchableOpacity onPress={() => removerItem(item.id)}>
                        <Text style={styles.removerBtn}>Remover</Text>
                      </TouchableOpacity>
                    )}
                  </View>
                  <Text style={styles.cardDescricao}>{item.descricao}</Text>
                  <TouchableOpacity
                    onPress={() => {
                      setAnuncianteSelecionado(item);
                      setPerfilVisivel(true);
                    }}>
                    <Text style={styles.cardUser}>
                      Dono:{' '}
                      <Text style={styles.linkVerde}>{item.usuarioEmail}</Text>
                    </Text>
                  </TouchableOpacity>
                </View>
              </View>
            )}
            ListEmptyComponent={
              <Text style={styles.empty}>Nenhum item disponível.</Text>
            }
          />
        )}
      </View>

      <Modal visible={perfilVisivel} animationType="fade" transparent={true}>
        <View style={styles.modalOverlay}>
          <View style={styles.modalConteudo}>
            <Text style={styles.modalTitulo}>Contato</Text>
            <Text style={styles.perfilLabel}>E-mail:</Text>
            <Text style={styles.perfilDado}>
              {anuncianteSelecionado?.usuarioEmail}
            </Text>
            <Text style={[styles.perfilLabel, { marginTop: 15 }]}>
              WhatsApp:
            </Text>
            <Text style={styles.perfilDado}>
              {anuncianteSelecionado?.usuarioTel}
            </Text>
            <TouchableOpacity
              style={styles.btnFecharModal}
              onPress={() => setPerfilVisivel(false)}>
              <Text style={styles.btnFecharTexto}>Voltar</Text>
            </TouchableOpacity>
          </View>
        </View>
      </Modal>

      <View style={styles.tabBarContainer}>
        <View style={styles.tabBar}>
          <TouchableOpacity
            style={[styles.tabItem, abaAtiva === 'home' && styles.tabAtiva]}
            onPress={() => setAbaAtiva('home')}>
            <Text
              style={
                abaAtiva === 'home' ? styles.tabTextAtivo : styles.tabText
              }>
              🏠 Início
            </Text>
          </TouchableOpacity>
          <TouchableOpacity
            style={[styles.tabItem, abaAtiva === 'perfil' && styles.tabAtiva]}
            onPress={() => setAbaAtiva('perfil')}>
            <Text
              style={
                abaAtiva === 'perfil' ? styles.tabTextAtivo : styles.tabText
              }>
              ➕ Novo
            </Text>
          </TouchableOpacity>
        </View>
      </View>
    </SafeAreaView>
  );
}

